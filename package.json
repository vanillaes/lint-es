{
  "name": "@vanillaes/lint-es",
  "version": "1.0.6",
  "description": "Modern linting for ECMAScript Modules",
  "keywords": [
    "ecmascript",
    "esm",
    "esmodules",
    "typescript",
    "cli",
    "developer-tools",
    "lint",
    "eslint",
    "standard",
    "neostandard"
  ],
  "repository": "https://github.com/vanillaes/lint-es",
  "author": "Evan Plaice <evanplaice@gmail.com>",
  "license": "MIT",
  "type": "module",
  "bin": {
    "lint-es": "bin/lint-es.js"
  },
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "default": "./src/index.js"
    }
  },
  "scripts": {
    "test": "esmtk test",
    "lint": "esmtk lint",
    "type": "esmtk type src/index.js --module nodenext && esmtk type bin/lint-es.js --module nodenext",
    "typings": "esmtk typings src/index.js",
    "clean": "esmtk clean --typings",
    "preview": "esmtk preview",
    "preversion": "npm run test && npm run lint",
    "postversion": "git push --follow-tags"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "eslint-plugin-jsdoc": "^62.8.1",
    "neostandard": "^0.13.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vanillaes/esmtk": "^1.2.3"
  }
}
