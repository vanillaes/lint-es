{
  "name": "@vanillaes/lint-es",
  "version": "1.0.18",
  "description": "Modern linting for ECMAScript Modules",
  "keywords": [
    "ecmascript",
    "esm",
    "esmodules",
    "typescript",
    "cli",
    "developer-tools",
    "lint",
    "eslint",
    "standard",
    "neostandard"
  ],
  "repository": "https://github.com/vanillaes/lint-es",
  "author": "Evan Plaice <evanplaice@gmail.com>",
  "license": "MIT",
  "type": "module",
  "bin": {
    "lint-es": "bin/lint-es.js"
  },
  "exports": {
    ".": {
      "import": "./src/index.js",
      "types": "./src/index.d.ts"
    }
  },
  "scripts": {
    "lint-es": "node ./bin/lint-es.js",
    "test": "esmtk test",
    "lint": "node ./bin/lint-es.js",
    "type": "esmtk type src/index.js --module nodenext --types node && esmtk type bin/lint-es.js --module nodenext --types node",
    "build": "esmtk typings --module nodenext --types node src/index.js",
    "clean": "esmtk clean --typings",
    "preview": "esmtk preview",
    "preversion": "npm run test && npm run lint && npm run type",
    "version": "npm run clean && npm run build && git add **/*.d.ts",
    "postversion": "git push --follow-tags"
  },
  "dependencies": {
    "@vanillaes/esmtk": "^2.4.1",
    "commander": "^14.0.3",
    "eslint-plugin-jsdoc": "^62.8.1",
    "neostandard": "^0.13.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0"
  }
}
