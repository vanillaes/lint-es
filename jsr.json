{
  "name": "@vanillaes/lint-es",
  "version": "1.0.12",
  "license": "MIT",
  "exports": {
    ".": "./src/index.js"
  },
  "publish": {
    "include": [
      "bin/**/*.js",
      "src/**/*.js",
      "src/**/*.d.ts",
      "LICENSE",
      "README.md"
    ],
    "exclude": [
      "**/__tests__/**",
      "bin/**/*.spec.js",
      "src/**/*.spec.js"
    ]
  }
}
